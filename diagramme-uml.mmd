classDiagram
    class Personne {
        <<abstract>>
        #int id
        -String nom
        -String prenom
        -String telephone
        +getId() int
        +getNom() String
        +setNom(String) void
        +getPrenom() String
        +setPrenom(String) void
        +getTelephone() String
        +setTelephone(String) void
        +afficherDetails()* void
        +toString() String
    }

    class Client {
        -String email
        -String adresse
        -int compteur$
        +getEmail() String
        +setEmail(String) void
        +getAdresse() String
        +setAdresse(String) void
        +afficherDetails() void
        +toString() String
    }

    class Livreur {
        -String vehicule
        -int compteur$
        +getVehicule() String
        +setVehicule(String) void
        +afficherDetails() void
        +toString() String
    }

    class Commande {
        -int id
        -String description
        -LocalDate dateCommande
        -int compteur$
        +getId() int
        +getClient() Client
        +getDescription() String
        +setDescription(String) void
        +getDateCommande() LocalDate
        +getStatut() StatutCommande
        +afficherCommande() void
        +modifierStatut(StatutCommande) void
        +toString() String
    }

    class Livraison {
        -int id
        -LocalDate dateLivraisonPrevue
        -LocalDate dateLivraisonReelle
        -int compteur$
        +getId() int
        +getCommande() Commande
        +getLivreur() Livreur
        +getDateLivraisonPrevue() LocalDate
        +getDateLivraisonReelle() LocalDate
        +getType() TypeLivraison
        +afficherLivraison() void
        +terminerLivraison() void
        +estTerminee() boolean
        +toString() String
    }

    class ServiceLivraison {
        -ArrayList~Client~ listeClients
        -ArrayList~Livreur~ listeLivreurs
        -ArrayList~Commande~ listeCommandes
        -ArrayList~Livraison~ listeLivraisons
        +ajouterClient(Client) void
        +supprimerClient(int) boolean
        +peutSupprimerClient(int) boolean
        +rechercherClientParId(int) Client
        +rechercherClientParNom(String) List~Client~
        +getClientsTriesParNom() List~Client~
        +getListeClients() List~Client~
        +ajouterLivreur(Livreur) void
        +supprimerLivreur(int) boolean
        +peutSupprimerLivreur(int) boolean
        +rechercherLivreurParId(int) Livreur
        +rechercherLivreurParNom(String) List~Livreur~
        +getLivreursTriesParNom() List~Livreur~
        +getListeLivreurs() List~Livreur~
        +creerCommande(Commande) void
        +supprimerCommande(int) boolean
        +peutSupprimerCommande(int) boolean
        +rechercherCommandeParId(int) Commande
        +rechercherCommandeParDescription(String) List~Commande~
        +getCommandesTrieesParDate() List~Commande~
        +getCommandesParClient(Client) List~Commande~
        +getCommandesEnLivraison() List~Commande~
        +getListeCommandes() List~Commande~
        +commandeDejaAffectee(int) boolean
        +affecterLivraison(Livraison) void
        +getLivraisonsEnCours() List~Livraison~
        +getLivraisonsTerminees() List~Livraison~
        +getListeLivraisons() List~Livraison~
        +getNombreCommandesLivrees() int
        +getNombreLivraisonsParLivreur(Livreur) int
        +getLivreurPlusActif() Livreur
    }

    class MenuCLI {
        +String RESET$
        +String BOLD$
        +String DIM$
        +String VERT$
        +String ROUGE$
        +String JAUNE$
        +String CYAN$
        -Terminal terminal
        -NonBlockingReader reader
        +selectionner(String, String[]) int
        +lireTexte(String) String
        +lireEntier(String) int
        +confirmer(String) boolean
        +afficherSucces(String) void
        +afficherErreur(String) void
        +afficherTitre(String) void
        +afficherInfo(String) void
        +pause() void
        +clearScreen() void
        +close() void
    }

    class Main {
        -MenuCLI cli$
        -ServiceLivraison service$
        +main(String[])$ void
        -chargerDonnees()$ void
        -menuClients()$ void
        -menuLivreurs()$ void
        -menuCommandes()$ void
        -menuLivraisons()$ void
        -menuStatistiques()$ void
    }

    class StatutCommande {
        <<enumeration>>
        EN_ATTENTE
        EN_PREPARATION
        EN_LIVRAISON
        LIVREE
        -String label
        +getLabel() String
        +toString() String
    }

    class TypeLivraison {
        <<enumeration>>
        STANDARD
        EXPRESS
        -String label
        +getLabel() String
        +toString() String
    }

    %% Heritage
    Personne <|-- Client
    Personne <|-- Livreur

    %% Associations avec cardinalites
    Client "1" <-- "0..*" Commande : client
    Commande "1" --> "1" StatutCommande : statut
    Commande "1" <-- "0..1" Livraison : commande
    Livreur "1" <-- "0..*" Livraison : livreur
    Livraison "1" --> "1" TypeLivraison : type

    %% Compositions (ServiceLivraison gere les collections)
    ServiceLivraison "1" *-- "0..*" Client : listeClients
    ServiceLivraison "1" *-- "0..*" Livreur : listeLivreurs
    ServiceLivraison "1" *-- "0..*" Commande : listeCommandes
    ServiceLivraison "1" *-- "0..*" Livraison : listeLivraisons

    %% Dependances
    Main --> ServiceLivraison : utilise
    Main --> MenuCLI : utilise
